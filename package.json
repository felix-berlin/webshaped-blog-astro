{
  "name": "webshaped-blog-frontend",
  "version": "1.11.1",
  "description": "My personal blog",
  "homepage": "https://webshaped.de",
  "bugs": {
    "url": "https://github.com/felix-berlin/webshaped-blog-astro/issues"
  },
  "author": {
    "name": "Felix Scholze",
    "email": "felix@webshaped.de",
    "url": "https://webshaped.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/felix-berlin/webshaped-blog-astro"
  },
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/felix-berlin"
    },
    {
      "type": "Ko-fi",
      "url": "https://ko-fi.com/felixberlin"
    },
    {
      "type": "PayPal",
      "url": "https://paypal.me/FelixScholze"
    },
    {
      "type": "Buy me a coffee",
      "url": "https://www.buymeacoffee.com/felixberlin"
    }
  ],
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:server": "export $(cat .env) && astro build",
    "build:strict": "astro check && tsc --noEmit && vue-tsc --noEmit && astro build",
    "preview": "export $(cat .env) && astro preview",
    "astro": "astro",
    "typechecking": "astro check && tsc --noEmit && vue-tsc --noEmit",
    "lint:js": "oxlint src/ --fix",
    "lint:style": "stylelint \"**/*.{scss,sass}\" --ignore-path .gitignore",
    "lint": "pnpm run lint:js && pnpm run lint:style",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:update": "vitest --update",
    "test:unit:ci": "vitest --coverage --reporter=junit --outputFile=test-report.junit.xml",
    "test:e2e": "pnpx playwright test",
    "test:e2e:ui": "pnpx playwright test --ui",
    "format": "pnpm exec oxfmt .",
    "format:check": "pnpm exec oxfmt --check .",
    "gql:generate": "graphql-codegen --config codegen.ts",
    "gql:generate:watch": "graphql-codegen --config codegen.ts --watch",
    "preinstall": "pnpx only-allow pnpm",
    "copy:pagefind": "pnpm dlx shx cp -r dist/pagefind public/",
    "predev": "pnpm run gql:generate"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vue": "^6.0.1",
    "@felix_berlin/sass-butler": "^3.1.1",
    "@fontsource/source-sans-pro": "^5.2.5",
    "@formkit/auto-animate": "^0.9.0",
    "@iconify-json/lucide": "^1.2.106",
    "@iconify-json/tabler": "^1.2.35",
    "@nanostores/i18n": "^1.3.2",
    "@nanostores/persistent": "^1.3.4",
    "@nanostores/vue": "^1.1.0",
    "@pagefind/default-ui": "^1.4.0",
    "@sentry/astro": "^10.52.0",
    "@spotlightjs/astro": "^3.2.6",
    "@urql/core": "^6.0.1",
    "@urql/exchange-graphcache": "^9.0.0",
    "@urql/vue": "^2.1.0",
    "@vueuse/core": "^14.3.0",
    "astro": "^6.3.1",
    "astro-breadcrumbs": "^3.4.0",
    "astro-capo": "^0.0.1",
    "astro-loading-indicator": "^0.8.0",
    "astro-matomo": "^1.10.0",
    "floating-vue": "5.2.2",
    "he": "^1.2.0",
    "nanostores": "^1.3.0",
    "pagefind": "^1.4.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "tm-themes": "^1.12.2",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.4",
    "@astrojs/check": "^0.9.9",
    "@codecov/astro-plugin": "^2.0.1",
    "@faker-js/faker": "^10.4.0",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@graphql-codegen/introspection": "^6.0.0",
    "@graphql-codegen/schema-ast": "^6.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.2",
    "@nanostores/logger": "^1.1.0",
    "@playform/inline": "0.1.4",
    "@playwright/test": "^1.57.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@shikijs/transformers": "^4.0.2",
    "@types/he": "^1.2.3",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/web-worker": "^4.1.5",
    "@vue/compiler-sfc": "^3.5.34",
    "@vue/devtools-api": "^8.1.2",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "graphql": "^16.14.0",
    "graphql-config": "^5.1.6",
    "jsdom": "^29.1.1",
    "msw": "^2.14.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.63.0",
    "postcss-html": "^1.8.1",
    "postcss-preset-env": "^11.2.1",
    "postcss-scss": "^4.0.9",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.97.1",
    "semantic-release": "^25.0.3",
    "sirv": "^3.0.2",
    "stylelint": "^17.11.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.11",
    "vite-plugin-graphql-loader": "^5.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "pnpm@11.0.9"
}
