---
import type { TranslationRoutes } from "@layouts/DefaultLayout.astro";

// import SetColorMode from "@components/SetColorMode.astro";
import StoreSetter from "@components/StoreSetter.vue";
import SourceSansPro400 from "@fontsource/source-sans-pro/files/source-sans-pro-latin-400-normal.woff2";
import SourceSansPro700 from "@fontsource/source-sans-pro/files/source-sans-pro-latin-700-normal.woff2";
import { getWebmentionsUrl } from "@utils/helpers.ts";
import { createLocalizedUrl } from "@utils/i18n/utils.ts";
import { Head } from "astro-capo";
import LoadingIndicator from "astro-loading-indicator/component";
// import { pwaInfo } from "virtual:pwa-info";
import { ClientRouter } from "astro:transitions";

export interface Props {
  lang: "de" | "en";
  seo: Seo;
  title: Title;
  translationsRoutes: TranslationRoutes;
}

export interface Seo {
  canonical?: string;
  metaDesc?: string;
  metaRobotsNofollow?: string;
  metaRobotsNoindex?: string;
  opengraphAuthor?: string;
  opengraphDescription?: string;
  opengraphImage?: {
    sourceUrl: string;
  };
  opengraphModifiedTime?: string;
  opengraphPublishedTime?: string;
  opengraphPublisher?: string;
  opengraphSiteName?: string;
  opengraphTitle?: string;
  opengraphType?: string;
  opengraphUrl?: string;
  readingTime?: number;
  title: string;
  twitterDescription?: string;
  twitterTitle?: string;
}

export interface SeoProps {
  lang: "de" | "en";
  seo: Seo;
  title: Title;
}

export interface Title {
  title: string;
}

const { lang, seo, title, translationsRoutes } = Astro.props;
const translations = translationsRoutes || {};
const isTaxonomy = translations?.taxonomy === "category";

// Separate taxonomy routes if applicable
// Remove the taxonomy key from translations, this was just for identification
// and not needed in the final routes
const taxonomyRoutes = isTaxonomy ? (({ taxonomy, ...rest }) => rest)(translations) : {};

// Create localized URLs excluding the taxonomy
const otherRoutes = Object.entries(translations).reduce<TranslationRoutes>((acc, [key, value]) => {
  if (key && key !== "undefined") {
    acc[key] = createLocalizedUrl(Astro.url.pathname, key, translations);
  }
  return acc;
}, {} as TranslationRoutes);

// Determine the full translation routes
const fullTranslationRoutes = isTaxonomy ? taxonomyRoutes : otherRoutes;

const webmentionUrl = getWebmentionsUrl(Astro.url);
---

<Head>
  <!-- TODO: Enable after lightmode is final: #9 -->
  <!-- <SetColorMode /> -->
  <ClientRouter />
  <LoadingIndicator color="var(--color-base)" height="2px" />

  <!-- FIXME: PWA is not working (manifest is not found ect.) -->
  <!-- {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />} -->
  <!-- <script src="/src/services/pwa.ts"></script> -->

  <!-- Global Metadata -->
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1" name="viewport" />

  <!-- Locale -->
  {
    Object.entries(fullTranslationRoutes).map(([key, value]) => {
      return <link href={value} hreflang={key} rel="alternate" />;
    })
  }
  {
    Object.keys(fullTranslationRoutes).length > 1 && (
      <link href={fullTranslationRoutes["de"]} hreflang="x-default" rel="alternate" />
    )
  }

  <!-- Favicon -->
  <link href="/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />
  <link href="/favicon-32x32.png" rel="icon" sizes="32x32" type="image/png" />
  <link href="/favicon-16x16.png" rel="icon" sizes="16x16" type="image/png" />
  <link color="#303956" href="/safari-pinned-tab.svg" rel="mask-icon" />
  <link href="/sitemap-index.xml" rel="sitemap" />
  <meta content="#ffffff" name="msapplication-TileColor" />
  <meta content="#ffffff" name="theme-color" />
  <meta content={Astro.generator} name="generator" />

  <link href={seo?.canonical || Astro.url} rel="canonical" />

  <!-- Primary Meta Tags -->
  <title set:text={seo?.title ? seo.title : title} />

  {seo?.title && <meta content={seo.title} name="title" />}
  {seo?.metaDesc && <meta content={seo.metaDesc} name="description" />}

  <!-- Open Graph / Facebook -->
  {seo?.opengraphType && <meta content={seo.opengraphType} property="og:type" />}
  {seo?.opengraphUrl && <meta content={seo.opengraphUrl} property="og:url" />}
  {seo?.opengraphTitle && <meta content={seo.opengraphTitle} property="og:title" />}
  {
    seo?.opengraphDescription && (
      <meta content={seo.opengraphDescription} property="og:description" />
    )
  }
  {
    seo?.opengraphImage?.sourceUrl && (
      <meta content={seo.opengraphImage.sourceUrl} property="og:image" />
    )
  }

  <!-- Twitter -->
  <meta content="summary_large_image" property="twitter:card" />
  {seo?.opengraphUrl && <meta content={seo.opengraphUrl} property="twitter:url" />}
  {seo?.twitterTitle && <meta content={seo.twitterTitle} property="twitter:title" />}

  {
    seo?.twitterDescription && (
      <meta content={seo.twitterDescription} property="twitter:description" />
    )
  }
  {
    seo?.opengraphImage?.sourceUrl && (
      <meta content={seo.opengraphImage.sourceUrl} property="twitter:image" />
    )
  }

  <!-- RSS auto discovery -->
  <link
    href={new URL(`${lang}/rss.xml`, Astro.site)}
    rel="alternate"
    title="Web Shaped"
    type="application/rss+xml"
  />

  <!-- Webmention -->
  <link href={`${webmentionUrl}/webmention`} rel="webmention" />
  <link href={`${webmentionUrl}/xmlrpc`} rel="pingback" />
  <link href="//webmention.io" rel="preconnect" />

  <link href="//cms.webshaped.de" rel="preconnect" />
  <link href="//analytics.webshaped.de" rel="preconnect" />

  <!-- Preloads -->
  <link as="font" crossorigin href={SourceSansPro400} rel="preload" type="font/woff2" />
  <link as="font" crossorigin href={SourceSansPro700} rel="preload" type="font/woff2" />

  <slot name="head" />
</Head>
<StoreSetter client:only="vue" lang={lang} locale-routes={fullTranslationRoutes} />
